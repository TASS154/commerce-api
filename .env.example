# ── Shared ──────────────────────────────────────────────
NODE_ENV=development

# ── API (apps/api) ──────────────────────────────────────
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000

# Database: leave empty to use embedded PGlite (zero Docker).
# For real Postgres (recommended for scale demos):
# DATABASE_URL=postgres://vespera:vespera@localhost:5432/vespera
DATABASE_URL=

# Rate limit (per IP, sliding window — stored in DB so it works across instances)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_AUTH_MAX=20

# Firebase Auth (Admin SDK). Leave empty to enable Demo Auth for recruiters.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# Or single JSON (base64 or raw):
# FIREBASE_SERVICE_ACCOUNT=

# Web Firebase client config (also used by apps/web)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Payment gateway — fill to switch from Mock → live adapter stub
# PAYMENT_PROVIDER=mock
# PAYMENT_SECRET_KEY=
# PAYMENT_PUBLIC_KEY=
# PAYMENT_WEBHOOK_SECRET=

# ── Web (apps/web) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DEMO_MODE=true
